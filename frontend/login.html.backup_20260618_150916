<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Entrar — Mais Equilibrium</title>
<link rel="icon" type="image/svg+xml" href="../assets/favicon-multi.svg">
<link rel="icon" type="image/png" sizes="32x32" href="../assets/favicon-multi-32.png">
<link rel="apple-touch-icon" href="../assets/apple-touch-multi.png">
<link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{--azul:#1860A8;--marinho:#15406E;--aqua:#54C0CC;--ambar:#F0B43C;--coral:#E45460;--ink:#16293c;--muted:#6c7f8e;--line:#e2ebf3;--mist:#F1F7FC;--risk:#C0392B;--riskbg:#FBE9EA}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter',system-ui,sans-serif;color:var(--ink);min-height:100vh;display:flex;align-items:center;justify-content:center;
  background:linear-gradient(160deg,#15406E,#1860A8 75%);position:relative;overflow:hidden}
h1,h2{font-family:'Quicksand',sans-serif}
.bgcv{position:absolute;inset:0;z-index:1;pointer-events:none}
.bgcv .cv{position:absolute;animation:spin var(--sp,9s) linear infinite}
@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
.card{position:relative;z-index:2;background:#fff;border-radius:24px;padding:40px 36px;width:100%;max-width:400px;box-shadow:0 30px 70px rgba(8,30,55,.4);margin:20px}
.brand{display:flex;flex-direction:column;align-items:center;gap:10px;margin-bottom:26px}
.brand .nm{font-family:'Quicksand';font-weight:700;color:var(--marinho);font-size:20px}
.brand .nm span{color:var(--azul)}
.brand small{font-size:10px;letter-spacing:.18em;color:var(--muted);font-weight:600}
.card h1{font-size:22px;color:var(--marinho);text-align:center}
.card .sub{text-align:center;color:var(--muted);font-size:14px;margin-top:6px;margin-bottom:24px}
.field{margin-bottom:16px}
.field label{display:block;font-size:13px;color:var(--muted);margin-bottom:6px;font-weight:500}
.field input{width:100%;border:1.5px solid var(--line);border-radius:12px;padding:13px 14px;font-size:15px;font-family:'Inter';transition:.15s}
.field input:focus{outline:none;border-color:var(--azul);box-shadow:0 0 0 3px rgba(24,96,168,.12)}
.btn{font-family:'Quicksand';font-weight:600;border:none;border-radius:13px;padding:15px;font-size:15px;cursor:pointer;width:100%;background:var(--azul);color:#fff;transition:.18s;margin-top:6px}
.btn:hover{background:var(--marinho)}.btn:disabled{opacity:.6;cursor:not-allowed}
.msg{font-size:13.5px;border-radius:11px;padding:12px 14px;margin-top:16px;display:none}
.msg.err{background:var(--riskbg);color:var(--risk);display:block}
.msg.ok{background:#E9F6EE;color:#1E8449;display:block}
.foot{text-align:center;margin-top:22px;font-size:12.5px}
.foot a{color:var(--azul);text-decoration:none;font-weight:600}
</style>
</head>
<body>

<svg width="0" height="0" style="position:absolute"><defs>
<g id="blade"><path d="M 13.2,-3.8 L 2.2,-3.8 Q 0,-3.8 0,-5.7 L 0,-46.6 Q 0,-48.5 1.9,-48.5 Q 3.9,-48.5 5.5,-46.6 L 24.4,-20.1 Q 25.2,-14 22.3,-8.4 Q 21,-6 19.4,-5.8 L 13.2,-3.8 Z"/></g>
<g id="catavento"><use href="#blade" fill="#1860A8"/><use href="#blade" fill="#54C0CC" transform="rotate(90)"/><use href="#blade" fill="#F0B43C" transform="rotate(180)"/><use href="#blade" fill="#E45460" transform="rotate(270)"/></g>
</defs></svg>

<div class="bgcv" id="bgcv"></div>

<div class="card">
  <div class="brand">
    <svg width="52" height="52" viewBox="-55 -55 110 110"><use href="#catavento"/></svg>
    <div class="nm">Mais <span>Equilibrium</span></div>
    <small>MED CENTER</small>
  </div>
  <h1>Bem-vindo</h1>
  <div class="sub">Entre na sua conta para continuar</div>

  <div class="field"><label>E-mail</label><input id="email" type="email" placeholder="seu@email.com" autocomplete="username"></div>
  <div class="field"><label>Senha</label><input id="senha" type="password" placeholder="••••••••" autocomplete="current-password"></div>
  <button class="btn" id="btnEntrar" onclick="entrar()">Entrar</button>
  <div class="msg" id="msg"></div>

  <div class="foot">Ainda não é cliente? <a href="../index.html">Conheça o Mais Equilibrium</a></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="../shared/config.js"></script>
<script>
const sb = window.maisClient;
const $ = (id) => document.getElementById(id);
function showMsg(t, tipo){ const m=$("msg"); m.textContent=t; m.className="msg "+tipo; }

document.addEventListener("keydown",(e)=>{ if(e.key==="Enter") entrar(); });

async function rotaPorPapel(userId){
  // 1. é equipe?
  const { data: eq } = await sb.from("equipe").select("papel,ativo").eq("auth_user_id", userId).maybeSingle();
  if (eq && eq.ativo){
    if (eq.papel === "gestor" || eq.papel === "financeiro") return "gestao.html";
    if (eq.papel === "recepcao") return "recepcao.html";
  }
  // 2. é cliente (titular)?
  const { data: as } = await sb.from("assinantes").select("id").eq("auth_user_id", userId).maybeSingle();
  if (as) return "area-cliente.html";
  return null; // sem perfil
}

async function entrar(){
  const email = $("email").value.trim();
  const senha = $("senha").value;
  if (!email || !senha){ showMsg("Preencha e-mail e senha.","err"); return; }
  const btn = $("btnEntrar"); btn.disabled = true; btn.textContent = "Entrando...";
  try{
    const { data, error } = await sb.auth.signInWithPassword({ email, password: senha });
    if (error){ showMsg("E-mail ou senha incorretos.","err"); return; }
    const destino = await rotaPorPapel(data.user.id);
    if (!destino){
      await sb.auth.signOut();
      showMsg("Sua conta ainda não tem um perfil vinculado. Fale com a clínica.","err");
      return;
    }
    showMsg("Tudo certo! Redirecionando...","ok");
    window.location.href = destino;
  }catch(e){
    console.error(e); showMsg("Erro ao entrar. Tente novamente.","err");
  }finally{
    btn.disabled = false; btn.textContent = "Entrar";
  }
}

// se já estiver logado, pula direto
(async ()=>{
  const { data } = await sb.auth.getSession();
  if (data.session){
    const destino = await rotaPorPapel(data.session.user.id);
    if (destino) window.location.href = destino;
  }
})();

// cataventos de fundo
(function(){
  const host=document.getElementById("bgcv"); const NS="http://www.w3.org/2000/svg";
  const pals=[["#54C0CC","#F0B43C","#E45460","#ffffff"],["#ffffff","#54C0CC","#F0B43C","#E45460"]];
  const pos=[[6,12,140,12],[82,8,90,9],[12,70,80,10],[78,66,110,14],[44,84,60,8]];
  pos.forEach((p,idx)=>{
    const s=document.createElementNS(NS,"svg"); s.setAttribute("viewBox","-55 -55 110 110");
    s.setAttribute("width",p[2]); s.setAttribute("height",p[2]); s.classList.add("cv");
    s.style.left=p[0]+"%"; s.style.top=p[1]+"%"; s.style.setProperty("--sp",p[3]+"s");
    s.style.opacity=idx<2?"0.5":"0.2"; if(idx%2)s.style.animationDirection="reverse";
    const c=pals[idx%pals.length];
    [0,90,180,270].forEach((rot,i)=>{ const u=document.createElementNS(NS,"use"); u.setAttribute("href","#blade"); u.setAttribute("fill",c[i]); u.setAttribute("transform","rotate("+rot+")"); s.appendChild(u); });
    host.appendChild(s);
  });
})();
</script>
</body>
</html>
